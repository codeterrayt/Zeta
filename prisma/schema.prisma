datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// NextAuth.js Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  // Custom Zeta fields
  role              Role              @default(USER)
  isOwner           Boolean           @default(false)
  projects          ProjectMember[]
  assignments       TaskAssignment[]
  reportedTasks     Task[]            @relation("ReportedTasks")
  comments          Comment[]
  attachments       Attachment[]
  auditLogs         AuditLog[]
  settings          Settings?
  authoredDocuments Document[]        @relation("AuthoredDocuments")
  auditLogComments  AuditLogComment[]
  notifications     Notification[]
  chatMembers       ChatMember[]
  chatMessages      ChatMessage[]
  chatGroupsOwned   ChatGroup[]       @relation("ChatGroupsOwned")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  USER
  ADMIN
}

model Settings {
  id        String  @id @default(cuid())
  userId    String  @unique

  // Dashboard Thresholds
  highFocusMax   Int @default(3)
  mediumFocusMax Int @default(6)

  // Timeline comment options
  askTimelineComment Boolean @default(true)

  // Real-time Notification Preference
  notificationsEnabled Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Project & Org Models
model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members       ProjectMember[]
  sprints       Sprint[]
  tasks         Task[]
  folders       Folder[]
  boardSections BoardSection[]
  documents     Document[]
}

model BoardSection {
  id        String @id @default(cuid())
  name      String
  order     Int    @default(0)
  projectId String

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([projectId, name])
}

model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  userId    String
  role      ProjectRole @default(VIEWER)
  createdAt DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

enum ProjectRole {
  VIEWER
  CONTRIBUTOR
  ADMIN
}

// Folder / Epic
model Folder {
  id        String @id @default(cuid())
  name      String
  projectId String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]
}

// Sprint
model Sprint {
  id        String    @id @default(cuid())
  name      String
  startDate DateTime?
  endDate   DateTime?
  projectId String

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks       Task[]
  comments    Comment[]
  attachments Attachment[]
}

// Tasks & Closure Table for Infinite Hierarchy
model Task {
  id          String    @id @default(cuid())
  title       String
  description String?   @db.Text
  status      String    @default("BACKLOG")
  points      Int?
  startDate   DateTime?
  endDate     DateTime?
  dueDate     DateTime?

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  sprintId String?
  sprint   Sprint? @relation(fields: [sprintId], references: [id], onDelete: Cascade)

  folderId String?
  folder   Folder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  creatorId String?
  reporter  User?   @relation("ReportedTasks", fields: [creatorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Dev Metadata
  commitIds  String?
  branchName String?
  repoName   String?
  githubUrl  String?

  assignments TaskAssignment[]
  comments    Comment[]
  documents   DocLink[]
  attachments Attachment[]

  // Closure Table Relationships
  ancestors   TaskClosure[] @relation("AncestorRelation")
  descendants TaskClosure[] @relation("DescendantRelation")
  auditLogs   AuditLog[]
}

enum TaskAssignmentRole {
  OWNER
  SECONDARY_OWNER
  POC
  ASSIGNEE
}

model TaskAssignment {
  id        String             @id @default(cuid())
  taskId    String
  userId    String
  role      TaskAssignmentRole @default(ASSIGNEE)
  createdAt DateTime           @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
}

model TaskClosure {
  ancestorId   String
  descendantId String
  depth        Int

  ancestor   Task @relation("AncestorRelation", fields: [ancestorId], references: [id], onDelete: Cascade)
  descendant Task @relation("DescendantRelation", fields: [descendantId], references: [id], onDelete: Cascade)

  @@id([ancestorId, descendantId])
}

// Comments & Reallocation Logs
model Comment {
  id                String  @id @default(cuid())
  content           String  @db.Text
  taskId            String?
  sprintId          String?
  userId            String
  isReallocationLog Boolean @default(false)

  task      Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  sprint    Sprint?  @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  parentId    String?
  parent      Comment?     @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Comment[]    @relation("CommentReplies")
  attachments Attachment[]
}

model Attachment {
  id        String  @id @default(cuid())
  name      String
  url       String
  size      Int
  type      String
  userId    String
  taskId    String?
  sprintId  String?
  commentId String?
  chatGroupId String?
  chatMessageId String?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  task    Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  sprint  Sprint?  @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  chatGroup ChatGroup? @relation(fields: [chatGroupId], references: [id], onDelete: Cascade)
  chatMessage ChatMessage? @relation(fields: [chatMessageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// Zeta-style Documentation
model Document {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  projectId String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author    User      @relation("AuthoredDocuments", fields: [authorId], references: [id], onDelete: Cascade)
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskLinks DocLink[]
}

model DocLink {
  id         String @id @default(cuid())
  documentId String
  taskId     String

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([documentId, taskId])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  details   String   @db.Text
  comment   String?  @db.Text
  userId    String
  taskId    String?
  createdAt DateTime @default(now())

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  task     Task?             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  comments AuditLogComment[]
}

model AuditLogComment {
  id         String   @id @default(cuid())
  content    String   @db.Text
  auditLogId String
  userId     String
  createdAt  DateTime @default(now())

  auditLog AuditLog @relation(fields: [auditLogId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailQueue {
  id          String    @id @default(cuid())
  to          String
  subject     String
  body        String    @db.Text
  status      String    @default("PENDING") // PENDING, SENT, FAILED
  attempts    Int       @default(0)
  createdAt   DateTime  @default(now())
  processedAt DateTime?
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // 'MENTION', 'PROJECT_ADDED', 'ASSIGNED', 'TASK_CHANGED', 'DUE_SOON'
  title     String
  content   String   @db.Text
  isViewed  Boolean  @default(false)
  link      String? // The redirection URL path
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatGroup {
  id                 String       @id @default(cuid())
  name               String?      // Null for 1-1 chat
  isGroup            Boolean      @default(false)
  ownerId            String?      // Null for 1-1 chat
  allowMemberRename  Boolean      @default(true) // Whether regular members can rename
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  members            ChatMember[]
  messages           ChatMessage[]
  attachments        Attachment[]
  owner              User?        @relation("ChatGroupsOwned", fields: [ownerId], references: [id], onDelete: SetNull)
}

model ChatMember {
  id          String    @id @default(cuid())
  chatGroupId String
  userId      String
  isAdmin     Boolean   @default(false)
  mutedUntil  DateTime? // Mute options
  lastReadAt  DateTime  @default(now())

  chatGroup ChatGroup @relation(fields: [chatGroupId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatGroupId, userId])
}

model ChatMessage {
  id          String   @id @default(cuid())
  chatGroupId String
  senderId    String
  content     String   @db.Text
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chatGroup   ChatGroup    @relation(fields: [chatGroupId], references: [id], onDelete: Cascade)
  sender      User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  attachments Attachment[]
}

model SystemSettings {
  id         String   @id @default("system")
  smtpHost   String?
  smtpPort   Int?
  smtpUser   String?
  smtpPass   String?
  smtpFrom   String?
  smtpSecure Boolean  @default(false)
  aiEnabled  Boolean  @default(true)
  aiModel    String   @default("gemini-1.5-pro")
  aiApiKey   String?
  updatedAt  DateTime @updatedAt
}

model UserInvite {
  id        String   @id @default(cuid())
  email     String   @unique
  role      Role     @default(USER)
  token     String   @unique
  isUsed    Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}
